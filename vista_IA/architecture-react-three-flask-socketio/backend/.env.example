DATABASE_URL=postgresql://habla_user:change-me@127.0.0.1:5432/habla_observer

# Alternative to DATABASE_URL:
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=habla_observer
POSTGRES_USER=habla_user
POSTGRES_PASSWORD=change-me

HABLA_AUTH_SESSION_HOURS=24
POSTGRES_CONNECT_TIMEOUT=4

# Default validation login for local/GitHub reviewers.
HABLA_DEFAULT_ADMIN_ENABLED=1
HABLA_DEFAULT_ADMIN_USER=admin
HABLA_DEFAULT_ADMIN_PASSWORD=admin
HABLA_DEFAULT_ADMIN_NAME=GitHub Validation Admin
# CyberLACE security layer. Keep disabled by default in templates; enable locally when testing.
CYBERLACE_ENABLED=false
CYBERLACE_MODE=monitor
CYBERLACE_TRANSPORT=import
CYBERLACE_REST_URL=http://127.0.0.1:8088
CYBERLACE_RUNTIME_DIR=runtime/cyberlace
