[Desktop Entry]
Version=1.0
Type=Application
Name=Mata Procesos Vista IA
Comment=Limpia puertos y PIDs de desarrollo de Vista IA
Exec=bash -lc 'desktop_file="$1"; script_dir="$(dirname "$desktop_file")"; "$script_dir/mata_procesos.sh" --hold' bash %k
Terminal=true
Icon=utilities-terminal
Categories=Development;
