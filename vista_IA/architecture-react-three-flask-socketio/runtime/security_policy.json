{
  "schema_version": 1,
  "mode": "guarded-autonomy",
  "description": "Security plane formal. Las capacidades de alto riesgo quedan activadas como categorias reconocidas, pero no se ejecutan en modo autonomo sin una regla especifica de allow.",
  "default_decision": "ask",
  "security_events_log": "runtime/security_events.jsonl",
  "operator_context": {
    "requested_by_user": true,
    "requested_at": "2026-05-17",
    "human_intent": "Reducir aprobaciones repetitivas durante ejecucion larga sin perder trazabilidad ni control.",
    "global_allow_requested": true,
    "global_allow_granted": false,
    "reason_global_allow_not_granted": "Autorizar shell, red, borrado, permisos, procesos y Docker sin scope ni expiracion eliminaria la funcion del security plane."
  },
  "operator_approval": {
    "enabled": true,
    "approval_file": "runtime/operator_approval.json",
    "password_hash_algorithm": "pbkdf2_sha256",
    "scope": "one persisted plan file by SHA-256 plus workspace plus command fingerprints",
    "effect": "Una aprobacion valida puede convertir decisiones ask en allow solo para comandos que ya existian en el plan aprobado."
  },
  "first_interaction": {
    "enabled": true,
    "module": "orchestrator.first_interaction",
    "launcher": "codex_first_interaction.sh",
    "behavior": "Al iniciar el workspace, leer politica, plan y aprobacion; pedir password una vez; crear o reutilizar operator_approval; ejecutar el plan autonomo."
  },
