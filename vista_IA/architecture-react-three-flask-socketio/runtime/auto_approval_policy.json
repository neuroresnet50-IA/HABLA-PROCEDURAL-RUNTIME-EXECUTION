{
  "schema_version": 1,
  "description": "Politica para ejecucion autonoma sin pulsar Enter. Solo aprueba comandos cuyo argv empieza exactamente por uno de estos prefijos.",
  "allowed_prefixes": [
    [
      "date"
    ],
    [
      "find"
    ],
    [
      "ls"
    ],
    [
      "rg"
    ],
    [
      "sed"
    ],
    [
      "python3",
      "-m",
      "py_compile"
    ],
    [
      "python3",
      "-m",
      "unittest"
    ],
    [
      "/home/neurodriver/ferrari_env/bin/python",
      "-m",
      "py_compile"
    ],
    [
      "/home/neurodriver/ferrari_env/bin/python",
      "-m",
      "unittest"
    ],
    [
      "npm",
      "run",
      "build"
    ]
  ],
  "blocked_executables": [
    "bash",
    "chmod",
    "chown",
    "curl",
    "dd",
    "docker",
    "kill",
    "mkfs",
    "mv",
    "rm",
    "rsync",
    "scp",
    "sh",
    "ssh",
    "sudo",
    "tee",
    "wget"
  ]
}
