{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-orchestrator.local/schemas/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "goal",
    "status",
    "priority",
    "dependencies",
    "expected_files",
    "validation_commands",
    "timeout_seconds",
    "max_retries",
    "mode",
    "checkpoint_key"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "blocked"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 0
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0
    },
    "mode": {
      "type": "string",
      "enum": [
        "smoke",
        "build",
        "medium",
        "long-run"
      ]
    },
    "checkpoint_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  }
}
